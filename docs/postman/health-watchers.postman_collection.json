{
  "info": {
    "name": "Health Watchers API",
    "description": "Complete API collection for Health Watchers. Import the companion environment file before use.\n\n**Quick start**\n1. Import `health-watchers.postman_environment.json`\n2. Set `admin_email` and `admin_password` in the environment\n3. Run **Auth → Login** — `jwt_token` is set automatically\n4. All subsequent requests use the token via collection-level bearer auth",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-refresh JWT if it is missing or expired",
          "const token = pm.environment.get('jwt_token');",
          "if (token) {",
          "  try {",
          "    const payload = JSON.parse(atob(token.split('.')[1]));",
          "    const expiresIn = payload.exp - Math.floor(Date.now() / 1000);",
          "    if (expiresIn > 60) return; // still valid",
          "  } catch (e) {}",
          "}",
          "// Token missing or near-expiry — re-login",
          "const email = pm.environment.get('admin_email');",
          "const password = pm.environment.get('admin_password');",
          "if (!email || !password) return;",
          "pm.sendRequest({",
          "  url: pm.environment.get('base_url') + '/api/v1/auth/login',",
          "  method: 'POST',",
          "  header: { 'Content-Type': 'application/json' },",
          "  body: { mode: 'raw', raw: JSON.stringify({ email, password }) }",
          "}, (err, res) => {",
          "  if (!err && res.code === 200) {",
          "    const data = res.json().data;",
          "    if (data && data.token) pm.environment.set('jwt_token', data.token);",
          "    if (data && data.refreshToken) pm.environment.set('refresh_token', data.refreshToken);",
          "  }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns token', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('token');",
                  "  pm.environment.set('jwt_token', data.token);",
                  "  if (data.refreshToken) pm.environment.set('refresh_token', data.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{admin_email}}\", \"password\": \"{{admin_password}}\"}"
            }
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user object', () => pm.expect(pm.response.json()).to.have.property('data'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{new_user_email}}\", \"password\": \"{{new_user_password}}\", \"firstName\": \"Test\", \"lastName\": \"User\", \"role\": \"DOCTOR\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.token) pm.environment.set('jwt_token', data.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refresh_token}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.environment.unset('jwt_token');",
                  "pm.environment.unset('refresh_token');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('email');",
                  "  pm.expect(data).to.have.property('role');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{admin_email}}\"}"
            }
          }
        }
      ]
    },
